# Documentation
include README.md
include LICENSE
include docs/Manual_v5.pdf

# Python build infrastructure
include pyproject.toml

# Package data
recursive-include src/pfsspecsim/config *
recursive-include src/pfsspecsim/etc/data *

# Scripts and configuration files
recursive-include scripts *.py *.defaults

# Exclude build artifacts
global-exclude *.pyc *.o *~ __pycache__ .DS_Store
